# 复制本文件为 `.env` 后填写密钥（勿将 `.env` 提交到版本库）
#
# DeepSeek 开放平台 API Key（上传 PDF 自动拆分/填字段强烈建议配置）
DEEPSEEK_API_KEY=

# 可选：OpenAI 兼容 endpoint，一般无需修改
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 模型：如 deepseek-v4-flash、deepseek-v4-pro（以控制台/文档为准）
DEEPSEEK_MODEL=deepseek-v4-flash

# 可选：OCR。默认 paddle（PaddleOCR）；若只用 Tesseract 则设为 tesseract
# OCR_ENGINE=paddle

# ── 本地对话 trace（JSON，默认 local_chat_traces/trace_<会话ID>.json）
# CHAT_TRACE_ENABLED=1
# CHAT_TRACE_DIR=local_chat_traces

# 对话历史卡片（完整会话快照，与 trace 同 id）
# 默认目录：local_chat_histories/*.json
